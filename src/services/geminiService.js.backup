import { GoogleGenAI } from "@google/genai";

const GEMINI_API_KEY = import.meta.env.VITE_GEMINI_API_KEY || '';
const MAX_RETRIES = 3;
const BASE_RETRY_DELAY = 1000;

// Initialize SDK with the new @google/genai pattern
let ai = null;

if (GEMINI_API_KEY) {
    ai = new GoogleGenAI({
        apiKey: GEMINI_API_KEY
    });
}

// Using the specific model version requested by the user
const CURRENT_MODEL = 'gemini-3-flash-preview';

const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

function extractRetryTime(errorMessage) {
    const retryMatch = errorMessage.match(/retry in (\d+(\.\d+)?)/i);
    return retryMatch ? Math.ceil(parseFloat(retryMatch[1])) : null;
}

/**
 * Parse and clean JSON response from AI
 */
function parseAIResponse(text) {
    try {
        // Remove markdown code blocks if present
        let cleaned = text.trim();
        cleaned = cleaned.replace(/^```json\s*/i, '');
        cleaned = cleaned.replace(/^```\s*/i, '');
        cleaned = cleaned.replace(/\s*```$/i, '');
        cleaned = cleaned.trim();
        
        // Parse JSON
        const parsed = JSON.parse(cleaned);
        return parsed;
    } catch (error) {
        console.error('Failed to parse AI response as JSON:', error);
        console.error('Raw response:', text);
        throw new Error('AI ส่งข้อมูลกลับมาไม่ใช่ JSON ที่ถูกต้อง');
    }
}

/**
 * Enhanced Prompt Formatter for Team Lead-level OKR Analysis - JSON Output
 */
function formatOKRDataToPrompt(dashboardData) {
    const { summary, objectives, contributors, comparison, atRisk } = dashboardData;

    let prompt = `คุณคือ **Strategic Business Partner & OKR Specialist** ระดับสูง 
หน้าที่ของคุณคือการกลั่นกรองข้อมูล OKR ที่ซับซ้อนให้กลายเป็น **อินไซท์เชิงกลยุทธ์ (Strategic Insights)** เพื่อนำเสนอต่อ Team Lead โดยตรง 

### 💡 ปรัชญาการสรุป:
1. **Team Lead First**: ไม่ต้องร่ายยาว เน้น "สิ่งที่เป็นปัญหา" และ "สิ่งที่สำเร็จจริง" 
2. **Impact Driven**: เชื่อมโยงตัวเลขเข้ากับผลกระทบต่อธุรกิจ (Business Impact)
3. **Action Oriented**: ทุกประเด็นที่สรุปควรนำไปสู่การตัดสินใจหรือการตั้งคำถามต่อได้

---

### 📊 ชุดข้อมูลดิบสำหรับวิเคราะห์ (Raw Data Context):

#### 1. ตัวชี้วัดหลักและสุขภาพขององค์กร (Key Metrics & Organizational Health)
`;

    if (summary) {
        const objCompletionRate = summary.objectiveCompletionRate?.toFixed(1) || '0.0';
        const krCompletionRate = summary.keyResultCompletionRate?.toFixed(1) || '0.0';
        const avgProgress = summary.avgObjectiveProgress?.toFixed(1) || '0.0';
        const teamSize = summary.totalMembers || 0;
        const checkIns = summary.totalObjectiveCheckIns || 0;
        const engagementRate = teamSize > 0 ? (checkIns / teamSize).toFixed(1) : '0';

        prompt += `- อัตราความสำเร็จของ Objectives: ${objCompletionRate}% (${summary.completedObjectives}/${summary.totalObjectives})
- อัตราความสำเร็จของ Key Results: ${krCompletionRate}% (${summary.completedKeyResults}/${summary.totalKeyResults})
- ความคืบหน้าเฉลี่ยรวม: ${avgProgress}%
- ระดับการมีส่วนร่วมของพนักงาน (Engagement): ${engagementRate} check-ins ต่อคน\n\n`;
    }

    if (comparison) {
        prompt += `#### 2. แนวโน้มและขีดความสามารถ (Trend Performance)
- ความเร็วในการดำเนินงาน (Velocity): ${comparison.progressTrend}
- ระดับความผูกพันภายในทีม (Engagement Trend): ${comparison.engagementTrend}
- การเปลี่ยนแปลงความสำเร็จเมื่อเทียบกับรอบก่อน: ${comparison.completionRateDelta > 0 ? '+' : ''}${comparison.completionRateDelta}%
- การเปลี่ยนแปลงของความคืบหน้า: ${comparison.avgProgressDelta > 0 ? '+' : ''}${comparison.avgProgressDelta}%\n\n`;
    }

    if (contributors && contributors.length > 0) {
        prompt += `#### 3. พลังขับเคลื่อนของบุคลากร (Human Capital Drivers)
`;
        contributors.slice(0, 5).forEach((person, index) => {
            prompt += `- ${person.employeeName} (${person.role}): คะแนนผลกระทบ ${person.contributedWeightScore} แต้ม, ทักษะเด่น: ${person.topSkill}, แนวโน้ม: ${person.trend}\n`;
        });
        prompt += `\n`;
    }

    if (objectives && objectives.length > 0) {
        prompt += `#### 4. สถานะความสำเร็จรายเป้าหมาย (Strategic Objectives Status)
`;
        objectives.slice(0, 8).forEach((obj, index) => {
            const priority = obj.objectiveType === 1 ? '🔥 Strategic (High)' : '⚡ Tactical (Medium)';
            prompt += `- ${obj.objectiveName}: ${obj.status} (${obj.objectiveProgress}%), ประเภท: ${priority}, น้ำหนักความสำคัญ: ${obj.weightScore}\n`;
        });
        prompt += `\n`;
    }

    if (atRisk && atRisk.length > 0) {
        prompt += `#### 5. ประเด็นวิกฤตและความเสี่ยง (Critical Risks)
`;
        atRisk.forEach((obj, index) => {
            prompt += `- 🔴 [วิกฤต]: ${obj.objectiveName} (คืบหน้าเพียง ${obj.objectiveProgress}%) - สาเหตุหลัก: ${obj.reason || 'ไม่มีการระบุเหตุผล'}\n`;
        });
        prompt += `\n`;
    }

    prompt += `---

### 📝 คำสั่งสำหรับการส่งข้อมูลกลับ (JSON Response Format)

**⚠️ สำคัญมาก: คุณต้องส่งข้อมูลกลับมาในรูปแบบ JSON เท่านั้น ไม่ต้องมี markdown หรือข้อความอื่นใดนอกจาก JSON object**

หลักการสำคัญ:
- โทนเชิงบวก มองไปข้างหน้า (Growth & Opportunity-driven)
- ทุกการวิเคราะห์ต้องอ้างอิงชื่อ Objective เสมอ
- ใช้ภาษาไทยเชิงผู้บริหาร สุภาพ มั่นใจ และสร้างพลัง
- เน้น "โอกาส + การเติบโต" มากกว่าการตำหนิ

กรุณาส่งข้อมูลกลับมาในรูปแบบ JSON ตาม Schema นี้เท่านั้น:

{
  "executiveSummary": {
    "healthScore": <number 1-10>,
    "healthReason": "<เหตุผลเชิงกลยุทธ์ที่ให้คะแนนนี้ 2-3 ประโยค>",
    "alignmentStatus": "on-track" หรือ "needs-focus",
    "keyAchievement": "<Achievement เชิงบวกที่สร้าง Momentum สูงสุด พร้อมอ้างอิง Objective>"
  },
  "winningObjectives": [
    {
      "objectiveName": "<ชื่อ Objective จริงจากข้อมูล>",
      "progress": <number ความคืบหน้า>,
      "contributors": ["<ชื่อผู้มีส่วนร่วมหลัก>"],
      "insight": "<ทำได้ดีเพราะอะไร จุดแข็งที่ควรต่อยอด 1-2 ประโยค>",
      "impactLevel": "high" หรือ "medium"
    }
  ],
  "growthOpportunities": [
    {
      "objectiveName": "<ชื่อ Objective จริงจากข้อมูล>",
      "currentStatus": "<On Track|At Risk|Behind>",
      "opportunity": "<โอกาสในการพัฒนา 1-2 ประโยค>",
      "unlock": "<สิ่งที่ช่วยปลดล็อก เช่น คน/เวลา/clarity>",
      "priority": "high" หรือ "medium" หรือ "low"
    }
  ],
  "actionPlan": [
    {
      "priority": <number 1-5>,
      "action": "<Action ที่แนะนำ ชัดเจนและ actionable>",
      "relatedObjective": "<ชื่อ Objective ที่เกี่ยวข้อง>",
      "expectedImpact": "<ผลกระทบที่คาดหวัง>",
      "actionType": "accelerate" หรือ "refocus" หรือ "expand"
    }
  ],
  "keyInsights": {
    "topPerformancePattern": "<pattern ของความสำเร็จที่สามารถ replicate ได้ 2-3 ประโยค>",
    "systemicOpportunity": "<โอกาสเชิงระบบที่จะช่วยหลาย Objective พร้อมกัน>",
    "teamStrength": "<จุดแข็งหลักของทีมที่ควร leverage>"
  }
}

**คำแนะนำเพิ่มเติม:**
- winningObjectives: เลือก 3-5 Objectives ที่ทำได้ดีที่สุด (progress สูง หรือ impact สูง)
- growthOpportunities: เลือก 2-4 Objectives ที่มีโอกาสพัฒนาสูง (ไม่จำเป็นต้องเป็น At Risk เท่านั้น)
- actionPlan: ให้ 3-5 actions ที่เป็นรูปธรรมและ actionable
- ทุก field ที่เป็นข้อความควรกระชับ ชัดเจน และเป็นประโยคสมบูรณ์
- ต้องใช้ข้อมูลจริงจากที่ให้ไป อย่าสร้างชื่อ Objective ขึ้นมาเอง

**ห้ามส่งข้อความอื่นใดนอกจาก JSON object ที่ valid **
ไม่ต้องมี \`\`\`json หรือ markdown wrapper ใดๆ (แต่ถ้ามีก็ไม่เป็นไร ระบบจะตัดออกให้)
(ภาพใหญ่ที่ Team Lead ต้องเข้าใจใน 1–2 นาทีแรก)

- ให้คะแนน **OKR Health Score (1–10)** พร้อมเหตุผลเชิงกลยุทธ์
- ประเมินว่าทีมกำลัง:
  - ✅ เดินตามกลยุทธ์องค์กรอย่างมีทิศทาง  
  - หรือ ⚠️ ยังมีโอกาสจัดโฟกัสให้คมขึ้น
- ระบุ **Achievement เชิงบวกที่สร้าง Momentum สูงสุด**  
  โดยต้องอ้างอิง Objective ที่เกี่ยวข้องอย่างชัดเจน

> เน้น “แนวโน้มและศักยภาพ” มากกว่าการวิจารณ์

---

#### 🚀 2. Winning Objectives & Strategies — สิ่งที่ทีมทำได้ดีและควรขยายผล
(สิ่งที่ควรนำไปเป็นต้นแบบ)

แสดงข้อมูลในรูปแบบตาราง เพื่อให้เห็นชัดว่า  
Objective ใดคือ “ตัวขับเคลื่อนความสำเร็จ” ของทีม

| Objective | Progress | ผู้มีส่วนร่วมหลัก | Insight เชิงบวก |
|---------|----------|------------------|----------------|
| <Objective Name> | xx% | <Employee / Team> | ทำได้ดีเพราะอะไร |
| <Objective Name> | xx% | <Employee / Team> | จุดแข็งที่ควรต่อยอด |

จากตารางด้านบน กรุณาวิเคราะห์:
- Objective ใดมี **Impact สูงเมื่อเทียบกับ effort**
- พฤติกรรมของ Top Contributors ที่ทำให้ Objective สำเร็จ
- แนวทางที่สามารถ replicate ไปยัง Objective อื่นได้

---

#### 🌱 3. Growth Opportunities — โอกาสในการยกระดับผลลัพธ์
(แทนการมองว่าเป็น “ปัญหา”)

โฟกัสที่ Objective ที่ยังไปได้ไกลกว่านี้ หากมีการสนับสนุนที่เหมาะสม

แสดงในรูปแบบตาราง:

| Objective | สถานะปัจจุบัน | โอกาสในการพัฒนา | สิ่งที่ช่วยปลดล็อก |
|---------|---------------|------------------|--------------------|
| <Objective Name> | On Track / At Risk | ยังเพิ่ม impact ได้ | เช่น คน / เวลา / clarity |
| <Objective Name> | On Track | มีศักยภาพเร่ง | เช่น decision / alignment |

จากนั้นสรุป:
- Objective ใด “แค่ต้องการแรงผลักเล็กน้อย” ก็จะดีขึ้นชัดเจน
- มี pattern เชิงระบบอะไรที่ถ้าปรับ จะช่วยหลาย Objective พร้อมกัน

---

#### 💡 4. Team Lead Action Plan — การต่อยอดความสำเร็จในรอบถัดไป
(เชิงบวก แต่ชัดเจนและ actionable)

เสนอ **Action สำหรับผู้บริหาร 3–5 ข้อ**  
โดยผูกกับ Objective ที่เกี่ยวข้องโดยตรง

| ลำดับ | Action ที่แนะนำ | Objective ที่เกี่ยวข้อง | Impact ที่คาดหวัง |
|------|----------------|------------------------|------------------|
| 1 | สนับสนุน / เร่ง | <Objective Name> | เพิ่ม progress / ลดความเสี่ยง |
| 2 | ปรับโฟกัส | <Objective Name> | ใช้ทรัพยากรได้คุ้มขึ้น |
| 3 | ขยายผล | <Objective Name> | สร้าง momentum ทีม |

เน้น:
- Action ที่ช่วย “ขยายสิ่งที่ทีมทำได้ดีอยู่แล้ว”
- การตัดสินใจที่ทำให้รอบถัดไปชัดเจนขึ้นกว่าเดิม

---

### 📌 ข้อกำหนดด้านภาษาและสไตล์
- ภาษาไทยเชิงผู้บริหาร สุภาพ มั่นใจ และสร้างพลัง
- ทุก insight ต้องอ้างอิง Objective อย่างชัดเจน
- ใช้ตารางเมื่อช่วยให้ Team Lead มองเห็นภาพเร็วขึ้น
- เน้น “โอกาส + การเติบโต” มากกว่าการตำหนิ

---

`;

    return prompt;
}

const geminiService = {
    isConfigured() {
        return !!ai;
    },

    getPrompt(dashboardData) {
        return formatOKRDataToPrompt(dashboardData);
    },

    async generateSummary(dashboardData) {
        if (!this.isConfigured()) {
            throw new Error('กรุณาตั้งค่า VITE_GEMINI_API_KEY ในไฟล์ .env');
        }

        const prompt = formatOKRDataToPrompt(dashboardData);

        for (let attempt = 1; attempt <= MAX_RETRIES; attempt++) {
            try {
                console.log(`Attempt ${attempt}: Sending enhanced prompt to Gemini (${CURRENT_MODEL})...`);

                const response = await ai.models.generateContent({
                    model: CURRENT_MODEL,
                    contents: [{ role: 'user', parts: [{ text: prompt }] }],
                    config: {
                        temperature: 0.65, // ปรับเพื่อความแม่นยำเชิงวิเคราะห์
                        maxOutputTokens: 2500,
                    }
                });

                if (!response.text) throw new Error('AI ส่งคำตอบกลับมาเป็นค่าว่าง');
                return response.text;

            } catch (error) {
                console.error(`Attempt ${attempt} error:`, error.message);

                const isQuotaError = error.message?.includes('429') || error.message?.toLowerCase().includes('quota');

                if (isQuotaError && attempt < MAX_RETRIES) {
                    const waitTime = extractRetryTime(error.message) || (Math.pow(2, attempt) * 1000 / 1000);
                    console.warn(`Quota limit. Waiting ${waitTime}s...`);
                    await sleep(waitTime * 1000);
                    continue;
                }

                if (error.message?.includes('404')) {
                    throw new Error(`ไม่พบ Model ${CURRENT_MODEL} หรือ Endpoint (404). กรุณาตรวจสอบการตั้งค่า Model Name`);
                }

                if (attempt === MAX_RETRIES) throw error;
                await sleep(BASE_RETRY_DELAY * attempt);
            }
        }
    },

    async askQuestion(dashboardData, question) {
        if (!this.isConfigured()) {
            throw new Error('Gemini API key is not configured');
        }

        const dataPrompt = formatOKRDataToPrompt(dashboardData);
        const fullPrompt = `${dataPrompt}\n\n---\n\n**คำถามเชิงลึกจาก Team Lead:**\n${question}\n\n**คำสั่ง:**\nตอบคำถามโดยรักษาภาพลักษณ์ของ Strategic Advisor ให้คำตอบที่เฉียบคม อ้างอิงตัวเลข และมีน้ำหนักเชิงการบริหาร`;

        for (let attempt = 1; attempt <= MAX_RETRIES; attempt++) {
            try {
                const response = await ai.models.generateContent({
                    model: CURRENT_MODEL,
                    contents: [{ role: 'user', parts: [{ text: fullPrompt }] }]
                });
                return response.text;
            } catch (error) {
                const isQuotaError = error.message?.includes('quota') || error.message?.includes('429');

                if (isQuotaError && attempt < MAX_RETRIES) {
                    const waitTime = extractRetryTime(error.message) || (BASE_RETRY_DELAY * attempt / 1000);
                    await sleep(waitTime * 1000);
                    continue;
                }

                if (attempt === MAX_RETRIES) {
                    throw new Error(`ไม่สามารถตอบคำถามได้: ${error.message}`);
                }
            }
        }
    }
};

export default geminiService;